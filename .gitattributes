# Нормализация окончаний строк: текстовые файлы в репозитории — LF,
# в рабочей копии Windows — CRLF (auto). Бинарные — без конверсии.
* text=auto eol=lf

*.js   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.svg  text eol=lf

*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.xlsx binary
*.pdf  binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
