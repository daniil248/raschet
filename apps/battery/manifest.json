{
  "id": "battery",
  "name": "Расчёт АКБ",
  "description": "Подбор ёмкости и конфигурации АКБ для ИБП. Загрузка таблиц разряда производителей (Kehua, Panasonic, SVC, Sonnenschein) в XLSX и точный расчёт по ним",
  "version": "1.0.0",
  "owner": "unassigned",
