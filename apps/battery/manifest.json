  "internalOnly": false,
  "subscriptionPlan": "free",
  "requires": [
    "shared/auth",
    "shared/battery-catalog",
    "shared/battery-picker",
    "shared/battery-s3-logic",
    "shared/battery-types",
    "shared/ups-catalog",
    "shared/ups-types",
    "shared/ups-verified"
