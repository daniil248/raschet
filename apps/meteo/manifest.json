{
  "id": "meteo",
  "name": "Метеоданные",
  "description": "Stand-alone модуль метеоданных: хранит наборы почасовых метеоизмерений («датасеты») внутри активного проекта, загрузка из источников (Open-Meteo, ASHRAE, RP5, CSV), графики и годовые таблицы.",
  "version": "1.1.0",
  "owner": "unassigned",
  "kind": "ui",
  "standalone": true,
  "path": "apps/meteo/",
  "icon": "blue",
  "badge": "active",
  "enabled": true,
  "internalOnly": false,
  "subscriptionPlan": "free",
  "requires": [
    "shared/draggable-modal",
    "shared/idb-store",
    "shared/meteo-util"
  ],
  "dbCollections": [],
  "permissions": [
    "meteo.use"
  ],
  "lsNamespacesOwned": [
    "meteo"
  ],
  "dependsOnContracts": {
    "storageKeys": [
      "idb:meteo.datasets.<pid>",
      "raschet.meteo.last-loc.v1",
      "raschet.project.<pid>.meteo.activeId.v1",
      "raschet.project.<pid>.meteo.annualCols.v1",
      "raschet.project.<pid>.meteo.autoFetchOk.v1",
      "raschet.project.<pid>.meteo.datasets.v1",
      "raschet.project.<pid>.meteo.globalFilter.v1"
    ],
    "events": {
      "emits": [],
      "consumes": []
    },
    "urlParams": [
      "navResult",
      "pid",
      "project",
      "return"
    ],
    "bridges": [
      "shared/meteo-bridge.js"
    ]
  }
}
