# GE Tools backend env (на сервере: server/.env, НЕ в git). Пример без секретов.
PORT=8090
# Postgres
DATABASE_URL=postgres://getools:CHANGE_ME@127.0.0.1:5432/getools
# Auth
JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_TTL_HOURS=720
# Google OAuth (опц., later — для входа через Gmail как было)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# SMTP (замена Cloud Functions Trigger Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=GE Tools <noreply@example.com>
# Публичный URL приложения (для ссылок в письмах)
APP_URL=https://example.com/
