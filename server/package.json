  },
  "dependencies": {
    "express": "^4.19.2",
    "google-auth-library": "^9.14.1",
    "pg": "^8.12.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "cors": "^2.8.5"
  },
  "engines": { "node": ">=20" }
}
