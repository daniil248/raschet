{
  "name": "getools-server",
  "version": "0.1.0",
  "private": true,
  "description": "GE Tools backend (Timeweb VPS): Postgres + Auth + Email — замена Firebase",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "setup": "npm install --omit=dev --no-audit --no-fund",
